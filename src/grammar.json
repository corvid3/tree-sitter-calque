{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "calque",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "SYMBOL",
        "name": "toplevel"
      }
    },
    "toplevel": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "decl"
        },
        {
          "type": "SYMBOL",
          "name": "expr"
        }
      ]
    },
    "let_tok": {
      "type": "TOKEN",
      "content": {
        "type": "STRING",
        "value": "let"
      }
    },
    "decl": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "let_tok"
        },
        {
          "type": "SYMBOL",
          "name": "ident"
        },
        {
          "type": "STRING",
          "value": "="
        },
        {
          "type": "SYMBOL",
          "name": "expr"
        }
      ]
    },
    "expr": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "apply"
        },
        {
          "type": "PATTERN",
          "value": ".*\\."
        }
      ]
    },
    "apply": {
      "type": "PREC",
      "value": 1,
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SYMBOL",
            "name": "factor"
          },
          {
            "type": "SYMBOL",
            "name": "concat"
          },
          {
            "type": "SEQ",
            "members": [
              {
                "type": "SYMBOL",
                "name": "apply"
              },
              {
                "type": "PATTERN",
                "value": "\\ +"
              },
              {
                "type": "SYMBOL",
                "name": "factor"
              }
            ]
          }
        ]
      }
    },
    "concat": {
      "type": "PREC",
      "value": 2,
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SEQ",
            "members": [
              {
                "type": "SYMBOL",
                "name": "concat"
              },
              {
                "type": "STRING",
                "value": ","
              },
              {
                "type": "SYMBOL",
                "name": "factor"
              }
            ]
          },
          {
            "type": "SYMBOL",
            "name": "factor"
          }
        ]
      }
    },
    "factor": {
      "type": "PREC",
      "value": 3,
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SYMBOL",
            "name": "number"
          },
          {
            "type": "SYMBOL",
            "name": "ident"
          },
          {
            "type": "SYMBOL",
            "name": "string"
          }
        ]
      }
    },
    "number": {
      "type": "PATTERN",
      "value": "\\d+"
    },
    "ident": {
      "type": "PATTERN",
      "value": "\\w"
    },
    "string": {
      "type": "PATTERN",
      "value": "\\\".*\\\""
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "\\s"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}